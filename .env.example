# ── Vitrine environment (copy to .env and fill in) ───────────────────────────
# See backend.md §15 for descriptions.

# core
ENV=local
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=postgresql+asyncpg://vitrine:vitrine@localhost:5432/vitrine
REDIS_URL=redis://localhost:6379/0
FRONTEND_ORIGIN=http://localhost:5173

# auth
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# openai  (server-side only — never expose to the browser)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_DAILY_LIMIT_USD=5
AGENT_MAX_RETRIES=2
AGENT_RUN_BUDGET_TOKENS=20000

# payments  (mock now, Stripe-ready)
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# hosting / previews  (allow-listed hosts for embedded sandboxed demos)
ALLOWED_PREVIEW_HOSTS=vercel.app,preview.vitrine.app
