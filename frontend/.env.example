# Vitrine frontend — copy to .env.local (or .env) and adjust.
# See backend.md §16 "Frontend <-> Backend wiring".

# API base. Dev = the gateway monolith. Prod = "/api" (nginx proxies to gateway).
VITE_API_BASE=http://localhost:8000

# Keep the built-in mock store (true) or talk to the real backend (false).
# Start at 'true', flip to 'false' once the backend is running + seeded.
VITE_USE_MOCKS=true
