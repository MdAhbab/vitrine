# Vitrine frontend — copy to .env.local (or .env) and adjust.
# See backend.md §16 "Frontend <-> Backend wiring".

# API base. Dev/Prod both use the local reverse proxy path.
VITE_API_BASE=/api
# Dev-only proxy target used by Vite when VITE_API_BASE is /api.
VITE_PROXY_TARGET=http://localhost:8000
# Dev-only direct fallback if a stale Vite server is missing the /api proxy.
VITE_DIRECT_API_BASE=http://127.0.0.1:8000

# Keep the built-in mock store (true) or talk to the real backend (false).
VITE_USE_MOCKS=false
